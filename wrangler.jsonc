{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "valabhiastrology",
  "compatibility_date": "2026-06-27",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
